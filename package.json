{
  "name": "odogwu-empire",
  "version": "0.1.0",
  "description": "A Nigerian-themed online multiplayer board game. Buy the land. Become the Odogwu.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:client": "vite build",
    "preview:client": "vite preview",
    "start": "tsx src/server/index.ts",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.5",
    "@vitejs/plugin-react": "^4.3.1",
    "colyseus": "0.16.1",
    "colyseus.js": "^0.16.22",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.1",
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-toastify": "^11.1.0"
  }
}
